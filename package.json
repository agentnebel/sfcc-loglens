    },
    "devDependencies": {
        "@types/node": "^20.12.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.2.0",
        "electron": "^29.4.6",
        "electron-builder": "^24.13.3",
        "typescript": "^5.4.0",
